<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Tether" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/black</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <style name="Theme.Tether.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#0F0F0F</item>
        <item name="windowSplashScreenAnimatedIcon">@android:color/transparent</item>
        <item name="postSplashScreenTheme">@style/Theme.Tether</item>
    </style>
</resources>
